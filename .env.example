# ──────────────────────────────────────────────
# Pharm-Agent Environment Configuration
# ──────────────────────────────────────────────

# Database
DATABASE_URL=postgresql://pharma:pharma@127.0.0.1:5433/pharma

# Redis (Celery broker/backend)
REDIS_URL=redis://127.0.0.1:6380/0

# LLM Provider
# Option 1: OpenRouter (Cloud — for production)
OPENROUTER_API_KEY=your_openrouter_key_here
LLM_MODEL=openai/gpt-4o-mini

# Option 2: Ollama (Local — for development)
# Unset OPENROUTER_API_KEY to use Ollama instead
# OLLAMA_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2

# MinIO / S3-compatible Object Storage
MINIO_ENDPOINT=127.0.0.1:9002
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio123
MINIO_USE_HTTPS=false

# Auth (CHANGE THESE IN PRODUCTION!)
API_KEY=supersecret
WORKER_TOKEN=workertoken

# CORS (comma-separated origins, use * for dev)
CORS_ORIGINS=*
